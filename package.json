{
  "name": "yls-workbench",
  "private": true,
  "packageManager": "bun@1.3.2",
  "scripts": {
    "verify:repo-layout": "node scripts/verify-repo-layout.mjs",
    "dev": "bun --cwd tauri-app run tauri dev",
    "build": "bun --cwd tauri-app run tauri build",
    "test": "bun --cwd tauri-app run test && cargo test --manifest-path tauri-app/src-tauri/Cargo.toml"
  }
}
